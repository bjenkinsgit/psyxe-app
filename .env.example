# This file is a template for a robust starting point of api keys and settings for the psyxe-app.
# Once you collect all of this information you can import this into your keychain from the running app via "File / Import .env".
# After you add more api keys and configuration information you can export and import those configurations via "File / Import Configuration".
# After you import all of this sensitive data, you can remove this file to a safe place so that no rogue malware can exfiltrate all of your api keys.

# Apple WeatherKit Configuration
# Get these from https://developer.apple.com/account/
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_WEATHERKIT_SERVICE_ID=com.example.weatherkit-client
APPLE_WEATHERKIT_KEY=YOUR_KEY_ID
APPLE_WEATHERKIT_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
# Alternative: paste PEM key contents directly (avoids file path / sandbox issues)
# APPLE_WEATHERKIT_PRIVATE_KEY_CONTENTS="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# OpenWeatherMap Configuration (fallback)
# Get API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# Temperature display preference: C/Celsius or F/Fahrenheit
TEMPERATURE_UNIT=F

# Brave Search
# Get API key from https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Apple Maps
APPLE_MAPS_ID=maps.com.yourcompany
APPLE_MAPS_KEY=XXXXXXX
APPLE_MAPS_PRIVATE_KEY_PATH=./AuthKey_NNNNNNNNN.p8
# Alternative: paste PEM key contents directly (avoids file path / sandbox issues)
# APPLE_MAPS_PRIVATE_KEY_CONTENTS="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# LLM Configuration
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=default
LLM_TIMEOUT_SECS=600
# LLM_API_KEY=sk-your-api-key  # Bearer token for authenticated endpoints (OpenAI, Azure, etc.)
# top_k sampling — limits token selection to the K most probable next tokens.
# vLLM only; automatically ignored for OpenAI API. Default (-1) = disabled.
#   top_k=1      greedy/deterministic (same as temperature=0)
#   top_k=10-20  focused, good for structured/factual output (tool calls, JSON)
#   top_k=50     moderate diversity, common general-purpose default
#   top_k=-1     disabled, consider all tokens (vLLM default)
# LLM_TOP_K=20
# Override model context window size (tokens) when /v1/models doesn't report it.
# Set this to the API-layer limit, not the raw model capacity.
# Example: GPT-5.2 raw model is 400k, but Responses API caps at 128k.
# LLM_MAX_CONTEXT=128000
#
# Override model output token limit (tokens). Only set this when the model has a
# SEPARATE output budget that doesn't count against the context window (e.g. vLLM
# serving a 400k-context model with a dedicated 128k output limit). When input and
# output share the same token pool (like OpenAI's Responses API), do NOT set this —
# the 15% ratio reserve is correct and avoids starving the input budget.
# LLM_MAX_OUTPUT_TOKENS=128000

# Gemini (image generation)
# Get API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# VirusTotal (URL scanning)
# Get API key from https://www.virustotal.com/
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Remote Embedding API (OpenAI-compatible endpoint)
# Used when memvid_config.toml has embedding_provider = "remote"
# EMBEDDING_API_URL=http://localhost:8000/v1/embeddings
# EMBEDDING_API_MODEL=intfloat/e5-mistral-7b-instruct

# Reasoning effort for LLM responses: low, medium, high
# Can also be set per-request via the UI or per-agent-role.
# LLM_REASONING_EFFORT=high

# Automation HTTP Server (localhost only, for Apple Shortcuts integration)
# Set a secret token to enable the server. Without this, the server won't start.
# AUTOMATION_API_KEY=your-secret-token
# AUTOMATION_PORT=19100

# Server-side reply delivery (resend.com)
# When set, the automation server sends replies directly — Apple Shortcuts
# become fire-and-forget (no polling loop needed, no 30-second timeout).
# Get API key from https://resend.com/
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL=Tauri Bot <bot@yourdomain.com>
# BOT_EMAIL — the iCloud address the bot listens on (used in mailto: links
# so email recipients can click to continue conversations).
# Can also be passed per-request via the "bot_email" field in /api/query.
# BOT_EMAIL=yourbot@icloud.com

# Code signing (macOS release builds only)
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAM_ID)"

## NON OBVIOUS ENV VARS THAT CAN BE SET IN SECURITY TAB
# SCHWAB_REDIRECT_URI=https://127.0.0.1:5556/callback  is created when user presses "connect to schwab" and lasts 3 minutes.
# SCHWAB_API_BASE_URL=https://api.schwabapi.com/marketdata/v1  #  Market data endpoints  
# SCHWAB_TOKEN_URL=https://api.schwabapi.com/v1/oauth/token    # OAuth token exchange
# SCHWAB_AUTHORIZE_URL=https://api.schwabapi.com/v1/oauth/authorize  # OAuth  browser login
